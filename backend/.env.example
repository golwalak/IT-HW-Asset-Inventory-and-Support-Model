# Server configuration
PORT=3001

# CORS origin (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Email provider: mock | smtp | graph
MAIL_PROVIDER=mock

# SMTP settings (used when MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Microsoft Graph settings (used for MAIL_PROVIDER=graph and DIRECTORY_PROVIDER=graph)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_UPN=

# Directory lookup provider: mock | graph
DIRECTORY_PROVIDER=mock

# Optional: link included in notification emails
PORTAL_URL=http://localhost:3000
